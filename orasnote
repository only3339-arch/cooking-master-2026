<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZenNotes - 森林療癒系雲端版</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700&family=Noto+Sans+TC:wght@300;400;500&display=swap');
        
        :root {
            --forest-bg: #5E8B8B;
            --forest-dark: #4A6B6B;
            --clay-orange: #D36449;
            --quokka-brown: #D9A07E;
            --paper-white: #F9F6F2;
            --text-main: #3D352F;
        }

        body { 
            font-family: 'Noto Sans TC', sans-serif; 
            background-color: var(--forest-bg);
            color: var(--text-main);
            transition: background-color 0.5s ease;
        }

        h1, h2, .font-serif { font-family: 'Noto Serif TC', serif; }
        .custom-shadow { box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.15); }
        .folder-item.active { background-color: var(--forest-dark); color: white; border-radius: 1.25rem; transform: translateX(5px); }
        .note-item.active { background-color: white; border-left: 6px solid var(--clay-orange); transform: scale(1.02); }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .editor-content:empty:before { content: attr(placeholder); color: #A09388; cursor: text; }
        .editor-content:focus { outline: none; }
        #note-sidebar { transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .sidebar-collapsed { width: 0px !important; opacity: 0; pointer-events: none; }
        .modal-bg { background-color: rgba(61, 53, 47, 0.6); backdrop-filter: blur(8px); }
        
        @keyframes sway { 0%, 100% { transform: rotate(-1deg); } 50% { transform: rotate(1deg); } }
        .animate-sway { animation: sway 4s ease-in-out infinite; }
        @keyframes nod { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(3px); } }
        .nodding { animation: nod 0.5s ease-in-out infinite; }

        /* Todo List Styles */
        .todo-item.completed span { text-decoration: line-through; opacity: 0.4; }
        .todo-item.completed .check-btn { background-color: var(--clay-orange); border-color: var(--clay-orange); color: white; }
        
        /* 讓輸入框看起來更像手寫 */
        .todo-input { border-bottom: 1px dashed transparent; transition: border-color 0.3s; }
        .todo-input:focus { border-bottom-color: var(--clay-orange); }
    </style>
</head>
<body class="h-screen flex overflow-hidden">

    <!-- 第一層：分類 -->
    <aside class="w-20 md:w-64 bg-[#4A6B6B] border-r border-white/10 flex flex-col z-20 text-white/80">
        <div class="p-8">
            <div class="flex items-center space-x-3 mb-2">
                <div class="w-8 h-8 bg-[#D36449] rounded-lg flex items-center justify-center text-white shadow-md">
                    <i class="fas fa-feather-alt"></i>
                </div>
                <h1 class="text-xl font-bold text-white hidden md:block">ZenNotes</h1>
            </div>
        </div>
        <div class="flex-1 px-4 space-y-6 overflow-y-auto no-scrollbar">
            <div id="folder-list" class="space-y-1"></div>
            <button onclick="addFolder()" class="w-full py-4 flex items-center justify-center text-white/40 hover:text-white border-2 border-dashed border-white/10 rounded-2xl transition-all">
                <i class="fas fa-plus-circle md:mr-2"></i>
                <span class="hidden md:inline text-sm font-medium">新分類</span>
            </button>
        </div>
        <div class="p-8 hidden md:block opacity-40 hover:opacity-100 transition-opacity">
            <div id="quokka-container" class="animate-sway">
                <svg viewBox="0 0 200 150" class="w-full">
                    <g id="quokka-head">
                        <circle cx="100" cy="80" r="35" fill="#D9A07E" />
                        <circle cx="80" cy="65" r="8" fill="#D9A07E" />
                        <circle cx="120" cy="65" r="8" fill="#D9A07E" />
                        <circle cx="95" cy="80" r="2" fill="#3D352F" />
                        <circle cx="105" cy="80" r="2" fill="#3D352F" />
                        <path d="M 98 88 Q 100 92 102 88" stroke="#3D352F" fill="none" stroke-width="2" />
                    </g>
                    <rect x="70" y="110" width="60" height="10" rx="5" fill="#D36449" />
                </svg>
            </div>
            <p class="text-[10px] text-center mt-2 tracking-[0.2em] text-white/30 font-bold">WRITING TOGETHER</p>
        </div>
    </aside>

    <!-- 第二層：清單 -->
    <section id="note-sidebar" class="w-72 md:w-80 bg-[#5E8B8B] border-r border-white/5 flex flex-col shadow-2xl z-10 overflow-hidden">
        <div class="p-8 flex justify-between items-center text-white">
            <h2 id="current-folder-name" class="font-bold text-lg truncate tracking-wide">筆記列表</h2>
            <button onclick="addNote()" class="w-10 h-10 rounded-2xl bg-white/10 hover:bg-[#D36449] text-white transition-all flex items-center justify-center group shadow-inner">
                <i class="fas fa-plus text-xs group-hover:rotate-90"></i>
            </button>
        </div>
        <div id="note-list" class="flex-1 overflow-y-auto p-4 space-y-4 no-scrollbar min-w-[280px]"></div>
    </section>

    <!-- 第三層：編輯器 -->
    <main class="flex-1 bg-[#F9F6F2] flex flex-col">
        <div class="h-20 border-b border-[#E5DDD3] px-8 flex items-center justify-between bg-white/30 backdrop-blur-md">
            <div class="flex items-center space-x-4">
                <button onclick="toggleSidebar()" class="w-11 h-11 rounded-2xl hover:bg-white text-[#5E8B8B] shadow-sm transition-all flex items-center justify-center border border-transparent hover:border-[#E5DDD3]">
                    <i id="toggle-icon" class="fas fa-indent"></i>
                </button>
                <div class="h-6 w-px bg-[#E5DDD3]"></div>
                
                <!-- 筆記模式切換 -->
                <button id="mode-toggle" onclick="toggleNoteMode()" class="w-11 h-11 rounded-2xl hover:bg-white text-[#8C7A66] transition-all flex items-center justify-center border border-transparent hover:border-[#E5DDD3]" title="切換待辦/純文字">
                    <i id="mode-icon" class="fas fa-tasks"></i>
                </button>

                <div class="h-6 w-px bg-[#E5DDD3]"></div>

                <div class="flex items-center space-x-2 bg-white/80 p-1.5 rounded-full shadow-sm border border-[#E5DDD3]">
                    <button onclick="execCmd('foreColor', '#D36449')" class="w-6 h-6 rounded-full bg-[#D36449]"></button>
                    <button onclick="execCmd('foreColor', '#4A6B6B')" class="w-6 h-6 rounded-full bg-[#4A6B6B]"></button>
                    <button onclick="execCmd('foreColor', '#D9A07E')" class="w-6 h-6 rounded-full bg-[#D9A07E]"></button>
                    <button onclick="execCmd('foreColor', '#3D352F')" class="w-6 h-6 rounded-full bg-[#3D352F]"></button>
                </div>
            </div>
            <div id="status-badge" class="text-[10px] font-bold text-[#A09388] tracking-[0.2em] bg-white/80 px-5 py-2.5 rounded-full shadow-sm border border-[#E5DDD3]">
                CONNECTING...
            </div>
        </div>

        <div class="flex-1 overflow-y-auto">
            <div class="max-w-3xl mx-auto py-20 px-10">
                <input type="text" id="editor-title" class="w-full text-5xl font-serif font-bold text-[#3D352F] bg-transparent focus:outline-none mb-10 placeholder-[#E5DDD3] border-none" placeholder="雲端標題...">
                
                <!-- 文字編輯區 -->
                <div id="editor-body" contenteditable="true" class="editor-content w-full text-xl leading-[2.2] text-[#4A3F35] min-h-[65vh]" placeholder="在雲端記錄靈感..."></div>
                
                <!-- 代辦清單區 -->
                <div id="todo-container" class="hidden space-y-4">
                    <div id="todo-list" class="space-y-3"></div>
                    <div class="pt-6 border-t border-[#E5DDD3]">
                        <button onclick="addTodoItem()" class="flex items-center space-x-3 text-[#D36449] font-bold hover:translate-x-2 transition-transform">
                            <i class="fas fa-plus-circle"></i>
                            <span>新增待辦事項</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script type="module">
        import { initializeApp } from 'https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js';
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from 'https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js';
        import { getFirestore, doc, setDoc, onSnapshot, collection, updateDoc, deleteDoc } from 'https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js';

        // 注意：在部署到 Netlify 時，請確保這裡的 config 是正確的
        const firebaseConfig = JSON.parse(__firebase_config);
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'zennotes-cloud';

        let data = { folders: [], notes: [], ui: { sidebarCollapsed: false } };
        let user = null;
        let currentFolderId = null;
        let currentNoteId = null;

        const folderListEl = document.getElementById('folder-list');
        const noteListEl = document.getElementById('note-list');
        const editorTitle = document.getElementById('editor-title');
        const editorBody = document.getElementById('editor-body');
        const todoContainer = document.getElementById('todo-container');
        const todoListEl = document.getElementById('todo-list');
        const statusBadge = document.getElementById('status-badge');
        const quokkaHead = document.getElementById('quokka-head');
        const modeIcon = document.getElementById('mode-icon');

        const initAuth = async () => {
            if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                await signInWithCustomToken(auth, __initial_auth_token);
            } else {
                await signInAnonymously(auth);
            }
        };

        onAuthStateChanged(auth, (u) => {
            user = u;
            if (user) startSyncing();
        });

        function startSyncing() {
            if (!user) return;
            
            // 同步設定
            onSnapshot(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'main'), (docSnap) => {
                if (docSnap.exists()) {
                    const cloudData = docSnap.data();
                    data.folders = cloudData.folders || [];
                    data.ui = cloudData.ui || { sidebarCollapsed: false };
                    renderFolders();
                    applySidebarState();
                } else {
                    migrateLocalStorage();
                }
            });

            // 同步筆記
            onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'notes'), (querySnapshot) => {
                const cloudNotes = [];
                querySnapshot.forEach((doc) => cloudNotes.push({ id: doc.id, ...doc.data() }));
                data.notes = cloudNotes;
                renderNotes();
                if (!currentNoteId && data.notes.length > 0) loadNote(data.notes[0].id);
            });
        }

        async function migrateLocalStorage() {
            if (!user) return;
            const rawLocal = localStorage.getItem('zennotes_v4');
            const localData = rawLocal ? JSON.parse(rawLocal) : {
                folders: [{ id: 'f1', name: '日常隨筆', icon: '🦦' }],
                notes: [{ id: 'n1', folderId: 'f1', title: '歡迎來到雲端', content: '資料已遷移！', updatedAt: Date.now(), isTodo: false, todos: [] }],
                ui: { sidebarCollapsed: false }
            };
            await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'main'), { folders: localData.folders, ui: localData.ui });
            for (const note of (localData.notes || [])) {
                await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'notes', note.id), note);
            }
        }

        window.addFolder = async () => {
            const name = prompt("分類名稱：", "新分類");
            if (!name || !user) return;
            const newId = 'f' + Date.now();
            data.folders.push({ id: newId, name, icon: '🌿' });
            await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'main'), { folders: data.folders, ui: data.ui }, { merge: true });
            currentFolderId = newId;
            window.addNote();
        };

        window.addNote = async () => {
            if (!user || !currentFolderId) return;
            const newId = 'n' + Date.now();
            await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'notes', newId), { 
                folderId: currentFolderId, title: '', content: '', updatedAt: Date.now(), isTodo: false, todos: [] 
            });
            loadNote(newId);
        };

        window.deleteNote = async (e, id) => {
            e.stopPropagation();
            if (confirm("刪除雲端內容？") && user) {
                await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'notes', id));
                if (currentNoteId === id) currentNoteId = null;
            }
        };

        function loadNote(id) {
            currentNoteId = id;
            const note = data.notes.find(n => n.id === id);
            if (note) {
                editorTitle.value = note.title;
                currentFolderId = note.folderId;
                if (note.isTodo) {
                    editorBody.classList.add('hidden');
                    todoContainer.classList.remove('hidden');
                    modeIcon.className = 'fas fa-align-left';
                    renderTodoList(note.todos || []);
                } else {
                    editorBody.classList.remove('hidden');
                    todoContainer.classList.add('hidden');
                    modeIcon.className = 'fas fa-tasks';
                    editorBody.innerHTML = note.content || '';
                }
            }
            renderFolders();
            renderNotes();
        }

        function renderTodoList(todos) {
            todoListEl.innerHTML = '';
            todos.forEach((todo, index) => {
                const div = document.createElement('div');
                div.className = `todo-item group flex items-center space-x-4 p-4 bg-white/40 rounded-3xl transition-all ${todo.completed ? 'completed' : ''}`;
                div.innerHTML = `
                    <button onclick="toggleTodo(${index})" class="check-btn w-7 h-7 rounded-full border-2 border-[#D36449] flex items-center justify-center transition-all">
                        ${todo.completed ? '<i class="fas fa-check text-xs"></i>' : ''}
                    </button>
                    <input type="text" value="${todo.text}" oninput="updateTodoText(${index}, this.value)" 
                        class="todo-input flex-1 bg-transparent border-none outline-none text-xl font-medium text-[#4A3F35]">
                    <button onclick="removeTodoItem(${index})" class="opacity-0 group-hover:opacity-100 text-rose-300 hover:text-rose-500 transition-opacity">
                        <i class="fas fa-trash-alt text-sm"></i>
                    </button>
                `;
                todoListEl.appendChild(div);
            });
        }

        window.toggleNoteMode = async () => {
            const note = data.notes.find(n => n.id === currentNoteId);
            if (!note) return;
            const newMode = !note.isTodo;
            await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'notes', currentNoteId), { isTodo: newMode, todos: note.todos || [] });
            loadNote(currentNoteId);
        };

        window.addTodoItem = () => {
            const note = data.notes.find(n => n.id === currentNoteId);
            const newTodos = [...(note.todos || []), { text: '', completed: false }];
            autoSave(newTodos);
        };

        window.toggleTodo = (index) => {
            const note = data.notes.find(n => n.id === currentNoteId);
            const newTodos = [...note.todos];
            newTodos[index].completed = !newTodos[index].completed;
            autoSave(newTodos);
        };

        window.updateTodoText = (index, text) => {
            const note = data.notes.find(n => n.id === currentNoteId);
            note.todos[index].text = text;
            autoSave(note.todos);
        };

        window.removeTodoItem = (index) => {
            const note = data.notes.find(n => n.id === currentNoteId);
            const newTodos = note.todos.filter((_, i) => i !== index);
            autoSave(newTodos);
        };

        let saveTimer;
        function autoSave(newTodos = null) {
            if (!user || !currentNoteId) return;
            statusBadge.innerText = "SYNCING...";
            quokkaHead.classList.add('nodding');
            clearTimeout(saveTimer);
            saveTimer = setTimeout(async () => {
                const note = data.notes.find(n => n.id === currentNoteId);
                const payload = { title: editorTitle.value, updatedAt: Date.now() };
                if (newTodos !== null) payload.todos = newTodos;
                else if (!note.isTodo) payload.content = editorBody.innerHTML;
                await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'notes', currentNoteId), payload);
                statusBadge.innerText = "CLOUD SAVED";
                quokkaHead.classList.remove('nodding');
            }, 800);
        }

        function renderFolders() {
            folderListEl.innerHTML = '';
            data.folders.forEach(f => {
                const div = document.createElement('div');
                div.className = `folder-item flex items-center p-4 cursor-pointer mb-1 ${f.id === currentFolderId ? 'active shadow-lg' : 'text-white/40 hover:text-white'}`;
                div.onclick = () => { currentFolderId = f.id; const notes = data.notes.filter(n => n.folderId === f.id); if (notes.length) loadNote(notes[0].id); else window.addNote(); };
                div.innerHTML = `<span class="mr-4 text-xl">${f.icon}</span><span class="truncate hidden md:inline text-sm font-bold tracking-wide">${f.name}</span>`;
                folderListEl.appendChild(div);
            });
        }

        function renderNotes() {
            noteListEl.innerHTML = '';
            const fNotes = data.notes.filter(n => n.folderId === currentFolderId).sort((a,b) => b.updatedAt - a.updatedAt);
            const activeFolder = data.folders.find(f => f.id === currentFolderId);
            document.getElementById('current-folder-name').innerText = activeFolder ? `${activeFolder.icon} ${activeFolder.name}` : '雲端筆記';
            fNotes.forEach(n => {
                const div = document.createElement('div');
                div.className = `note-item p-7 rounded-[2.5rem] cursor-pointer mb-4 ${n.id === currentNoteId ? 'active shadow-xl' : 'bg-white/5 text-white/90'}`;
                div.onclick = () => loadNote(n.id);
                div.innerHTML = `<div class="flex justify-between items-start"><div class="overflow-hidden"><h3 class="font-bold text-sm truncate mb-2">${n.isTodo ? '📋 ' : ''}${n.title || '（無標題）'}</h3><p class="text-[10px] opacity-40 uppercase font-black">${new Date(n.updatedAt).toLocaleDateString()}</p></div><button onclick="deleteNote(event, '${n.id}')" class="text-[#D36449]"><i class="fas fa-times-circle"></i></button></div>`;
                noteListEl.appendChild(div);
            });
        }

        window.execCmd = (cmd, val = null) => { document.execCommand(cmd, false, val); autoSave(); };
        window.toggleSidebar = async () => { data.ui.sidebarCollapsed = !data.ui.sidebarCollapsed; applySidebarState(); await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'main'), { ui: data.ui }); };
        function applySidebarState() { const sidebar = document.getElementById('note-sidebar'); const icon = document.getElementById('toggle-icon'); if (data.ui && data.ui.sidebarCollapsed) { sidebar.classList.add('sidebar-collapsed'); icon.className = 'fas fa-outdent'; } else { sidebar.classList.remove('sidebar-collapsed'); icon.className = 'fas fa-indent'; } }

        editorTitle.addEventListener('input', () => autoSave());
        editorBody.addEventListener('input', () => autoSave());
        initAuth();
    </script>
</body>
</html>
